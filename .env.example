# Configuración del Proyecto - Sistema de Convalidaciones USIL
# Copia este archivo a .env y actualiza los valores según tu entorno

# Servidor de Desarrollo
PORT=5500
HOST=localhost

# Modo
ENV=development
# production | development | testing

# Base de datos (futuro)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=convalidaciones_usil
# DB_USER=root
# DB_PASSWORD=

# API (futuro)
# API_URL=http://localhost:8000
# API_KEY=

# Rutas relativas (importantes para que funcione)
# NOTA: El servidor debe servir archivos desde la raíz del proyecto
# Las rutas relativas son: ../../shared/js/icons.js desde public/modulos/*/

# Características
FEATURE_EXCEL_IMPORT=false
FEATURE_PDF_EXPORT=false
FEATURE_API_INTEGRATION=false

# Logging
LOG_LEVEL=info
# error | warn | info | debug

# CORS (futuro)
# CORS_ORIGIN=http://localhost:3000

# Sesión (futuro)
# SESSION_SECRET=your-secret-key

